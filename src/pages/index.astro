---
import MainLayout from "../layouts/MainLayout.astro";
import { description, name } from "../info";

export const prerender = true;
---

<MainLayout>
    <div class="min-h-screen flex flex-col">
        <header class="flex justify-end p-4 sm:p-6">
            <a
                href="/blog"
                class="p-3 border-2 border-black dark:border-white rounded-md text-lg font-bold hover:underline"
            >
                Blog
            </a>
        </header>

        <main class="flex flex-1 items-center justify-center px-4 pb-10">
            <div class="w-full max-w-6xl">
                <div class="text-center">
                    <h1 class="text-4xl font-bold">{name}</h1>
                    <h2 class="text-2xl mt-4">{description}</h2>
                </div>

                <div class="grid gap-4 md:grid-cols-2 mt-8">
                    <section
                        class="border-2 border-black dark:border-white rounded-md p-5 flex flex-col"
                    >
                        <h2 class="text-2xl font-bold">Work</h2>
                        <p class="text-lg mt-4">
                            I'm actively looking for work. I'm strongest with
                            TypeScript, Go, full-stack development, developer
                            tools, Postgres, infrastructure tooling, and
                            practical product engineering.
                        </p>
                        <p class="text-lg mt-4">
                            I'm open to roles in the UK, EU, or US, including
                            full-time work and contract projects.
                        </p>
                        <button
                            type="button"
                            class="p-3 border-2 border-black dark:border-white rounded-md text-lg font-bold mt-6 w-full hover:underline"
                            data-contact-category="work"
                        >
                            Contact about work
                        </button>
                    </section>

                    <section
                        class="border-2 border-black dark:border-white rounded-md p-5 flex flex-col"
                    >
                        <h2 class="text-2xl font-bold">London Property</h2>
                        <p class="text-lg mt-4">
                            I'm looking for property in London. If you know of a
                            suitable flat, room, rental, or lead, I'd like to
                            hear about it.
                        </p>
                        <p class="text-lg mt-4">
                            Note that due to my previous landlord, I cannot give a
                            tenancy reference, however I can provide proof I can pay
                            and a letter from the council.
                        </p>
                        <button
                            type="button"
                            class="p-3 border-2 border-black dark:border-white rounded-md text-lg font-bold mt-6 w-full hover:underline"
                            data-contact-category="property"
                        >
                            Contact about property
                        </button>
                    </section>
                </div>
            </div>
        </main>
    </div>

    <dialog id="modal" class="fixed inset-0 z-50">
        <div class="fixed inset-0 bg-black bg-opacity-50"></div>
        <div class="fixed inset-0 flex items-center justify-center">
            <div
                class="bg-white dark:bg-gray-900 dark:text-white p-4 mx-4 border-8 border-black rounded-lg max-w-2xl"
                id="modal_content"
            >
                <header>
                    <div class="flex space-x-3">
                        <form method="dialog">
                            <button aria-label="Close" class="text-2xl">
                                ✖
                            </button>
                        </form>
                        <h1 class="text-2xl font-bold" id="modal_title">
                            Contact Me
                        </h1>
                    </div>
                </header>
                <hr class="my-4 dark:border-gray-600 border-gray-300" />
                <p class="text-lg" id="modal_intro">
                    Want to contact me personally? Write a message here and
                    presuming it isn't spam, I'll get back to you as soon as
                    possible!
                </p>

                <div
                    id="error"
                    class="hidden p-4 bg-red-600 text-white rounded-md mt-4 text-lg"
                >
                </div>

                <form method="post" id="contact_form">
                    <input
                        type="hidden"
                        name="category"
                        id="contact_category"
                    />
                    <input
                        type="email"
                        name="email"
                        placeholder="Your Email"
                        class="p-2 border-2 border-gray-300 dark:border-gray-600 rounded-md w-full mt-4 dark:bg-gray-900"
                        required
                    />
                    <textarea
                        name="message"
                        placeholder="Your Message"
                        class="p-2 border-2 border-gray-300 dark:border-gray-600 rounded-md w-full mt-4 dark:bg-gray-900"
                        required></textarea>
                    <div
                        class="cf-turnstile mt-4"
                        data-sitekey={process.env.TURNSTILE_SITE_KEY}
                    >
                    </div>
                    <button
                        type="submit"
                        class="p-2 border-2 border-black dark:border-white rounded-md w-full mt-4"
                    >
                        Send
                    </button>
                </form>
            </div>
        </div>
    </dialog>
</MainLayout>

<script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer></script>

<script>
    import { actions } from "astro:actions";

    const modal = document.getElementById("modal") as HTMLDialogElement;
    const modalTitle = document.getElementById("modal_title")!;
    const modalIntro = document.getElementById("modal_intro")!;
    const categoryInput = document.getElementById(
        "contact_category",
    ) as HTMLInputElement;

    const contactCopy = {
        work: {
            title: "Contact About Work",
            intro: "Tell me about the role, project, timeline, and the best way to follow up.",
        },
        property: {
            title: "Contact About Property",
            intro: "Tell me about the London property, location, rent, move-in timing, and the best way to follow up.",
        },
    } as const;

    document
        .querySelectorAll<HTMLButtonElement>("[data-contact-category]")
        .forEach((button) => {
            button.onclick = () => {
                const category = button.dataset
                    .contactCategory as keyof typeof contactCopy;
                const copy = contactCopy[category];

                categoryInput.value = category;
                modalTitle.textContent = copy.title;
                modalIntro.textContent = copy.intro;
                modal.showModal();
            };
        });

    // Close the modal when the user clicks on it.
    modal.onclick = () => {
        modal.close();
    };

    // Prevent the modal from closing when the user clicks on the content.
    document.getElementById("modal_content")!.onclick = (event) => {
        event.stopPropagation();
    };

    // Hides all messages in the modal.
    const hideMessages = () => {
        document.getElementById("error")!.classList.add("hidden");
    };

    // Shows the message in the modal.
    const showError = (error: string) => {
        const message = document.getElementById("error")!;
        message.textContent = error;
        message.classList.remove("hidden");
    };

    // Handle the form submission.
    document.getElementById("contact_form")!.onsubmit = async (event) => {
        event.preventDefault();
        hideMessages();

        const form = event.target as HTMLFormElement;
        const formData = new FormData(form);
        const category = formData.get("category");

        if (category !== "work" && category !== "property") {
            showError("Choose a contact category.");
            return;
        }

        const { data, error } = await actions.submitContactForm({
            category,
            email: formData.get("email") as string,
            message: formData.get("message") as string,
            token: (window as any).turnstile.getResponse(),
        });
        if (error) {
            showError(error.message);
        } else {
            const { success, error } = data;
            if (success) {
                form.reset();
                (window as any).turnstile.reset();
                modal.close();
            } else {
                showError(error);
            }
        }
    };
</script>
